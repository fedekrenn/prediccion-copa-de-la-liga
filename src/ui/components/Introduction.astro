<section class="section-card mx-auto flex w-full max-w-5xl flex-col gap-5 px-5 py-6 sm:px-7 sm:py-7">
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-3xl space-y-3">
      <span class="accent-chip">Como se calcula</span>
      <h2 class="text-balance text-2xl font-bold text-white sm:text-3xl">
        Un panel mas claro para leer la temporada en segundos
      </h2>
      <p class="text-sm leading-7 text-slate-300 sm:text-base">
        La proyeccion estima como podria terminar la tabla anual a partir del
        rendimiento actual de cada equipo en el torneo en curso, mostrando de
        forma mas clara la carrera por Libertadores, Sudamericana y permanencia.
      </p>
    </div>

    <div class="subtle-outline flex min-w-fit flex-col gap-1 rounded-2xl px-4 py-3">
      <span class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">
        Punto de referencia
      </span>
      <p class="text-lg font-bold text-white sm:text-xl">
        ~40 pts para evitar el descenso
      </p>
    </div>
  </div>

  <div class="flex flex-wrap items-center justify-between gap-4 border-t border-white/8 pt-4">
    <p class="max-w-3xl text-sm text-slate-400">
      Los datos se actualizan en tiempo real, incluso si hay equipos jugando.
    </p>
    <button
      id="show-dialog"
      class="rounded-full border border-white/10 bg-white/5 px-5 py-2.5 text-sm font-semibold text-white transition hover:border-emerald-300/40 hover:bg-emerald-400/10"
    >
      Ver metodologia
    </button>
  </div>

  <dialog id="dialog">
    <div class="relative flex flex-col gap-5 p-6 sm:p-8">
      <button
        id="close-dialog-icon"
        class="absolute right-4 top-4 flex h-10 w-10 items-center justify-center rounded-full border border-white/10 bg-white/5 text-lg text-slate-300 transition hover:bg-white/10 hover:text-white"
        aria-label="Cerrar modal"
      >
        x
      </button>

      <div class="space-y-3">
        <span class="accent-chip">Metodologia</span>
        <h3 class="text-2xl font-bold text-white sm:text-3xl">
          Que conviene tener en cuenta al leer la tabla
        </h3>
      </div>

      <div class="space-y-4 text-sm leading-7 text-slate-300 sm:text-base">
        <p>
          La tabla es <strong>dinamica</strong> y se alimenta de una fuente que se
          <strong>actualiza automaticamente</strong>, por lo que la informacion puede
          cambiar mientras se disputan partidos.
        </p>
        <p>
          El calculo usa el porcentaje de efectividad actual de cada equipo en el
          torneo vigente para <strong>proyectar</strong> cuantos puntos sumaria al final
          del campeonato si mantiene ese ritmo.
        </p>
        <p>
          Esa proyeccion se traduce en una lectura estimada de copas y descenso.
          Es una herramienta orientativa, no una garantia del resultado final.
        </p>
      </div>

      <button
        id="close-dialog"
        class="mt-2 rounded-full bg-emerald-400 px-5 py-3 text-sm font-bold text-slate-950 transition hover:bg-emerald-300"
      >
        Entendido
      </button>
    </div>
  </dialog>
</section>

<script>
  const $dialog = document.getElementById("dialog") as HTMLDialogElement;
  const $showDialogButton = document.getElementById("show-dialog");
  const $closeDialogButton = document.getElementById("close-dialog");
  const $closeDialogIcon = document.getElementById("close-dialog-icon");

  if ($dialog && $showDialogButton) {
    $showDialogButton.addEventListener("click", () => {
      $dialog.showModal();
    });
  }

  if ($dialog && $closeDialogButton) {
    $closeDialogButton.addEventListener("click", () => {
      $dialog.close();
    });
  }

  if ($dialog && $closeDialogIcon) {
    $closeDialogIcon.addEventListener("click", () => {
      $dialog.close();
    });
  }
</script>
