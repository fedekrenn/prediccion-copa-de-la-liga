---
import Footer from "@components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content="Prediccion de posiciones, clasificacion a copas y descenso para la LPF Argentina 2026 con datos actualizados automaticamente."
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="shortcut icon" href="favicon.png" type="image/x-icon" />
    <title>{title}</title>
  </head>
  <body>
    <div class="mx-auto min-h-screen w-full max-w-6xl px-4 py-5 sm:px-6 lg:px-8 lg:py-8">
      <slot />
      <Footer />
    </div>
  </body>
</html>
