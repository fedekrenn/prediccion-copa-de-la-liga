---
interface Props {
  title: string;
}

const { title } = Astro.props;
const siteUrl = "https://prediccion-copa-liga.vercel.app";
const description =
  "Documentacion de la API para la prediccion de la Liga Profesional Argentina 2026.";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL("/favicon.png", siteUrl).toString();
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#07131f" />
    <meta name="robots" content="noindex,nofollow" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preconnect" href="https://unpkg.com" crossorigin />
    <link rel="icon" href="/favicon.png" type="image/png" />
    <link
      rel="stylesheet"
      href="https://unpkg.com/swagger-ui-dist@5.27.1/swagger-ui.css"
    />
    <title>{title}</title>
  </head>
  <body class="px-3 md:px-5 mx-auto">
    <slot />
  </body>
</html>
